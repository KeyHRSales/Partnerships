    border-color:var(--black);
    transform:translateY(-2px);
    box-shadow:0 12px 32px rgba(11,11,13,.08);
  }
  .form-card-icon{
    flex-shrink:0;
    width:44px;height:44px;
    display:flex;align-items:center;justify-content:center;
    background:var(--red-soft);
    color:var(--red);
