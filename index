  /* ---------- FOOTER ---------- */
  footer{
    background:#050506;color:var(--grey-300);
    padding:60px 0 36px;border-top:1px solid rgba(255,255,255,.06);
  }
  .footer-grid{
    display:grid;grid-template-columns:1.6fr 1fr;gap:48px;
    margin-bottom:48px;
  }
  @media (max-width:780px){.footer-grid{grid-template-columns:1fr;gap:32px}}
  .footer-logo img{height:42px;width:auto;margin-bottom:16px}
  .footer-tag{
    font-family:var(--serif);font-style:italic;font-size:15px;
    color:var(--grey-300);max-width:300px;line-height:1.5;
  }
  .footer-col h4{
    font-size:11px;font-weight:700;letter-spacing:.18em;
    text-transform:uppercase;color:var(--white);margin-bottom:18px;
  }
  .footer-col a{
    display:block;font-size:14px;color:var(--grey-300);
    padding:6px 0;transition:color .2s;
  }
  .footer-col a:hover{color:var(--red)}
  .footer-bottom{
    display:flex;justify-content:space-between;align-items:center;
    padding-top:28px;border-top:1px solid rgba(255,255,255,.08);
    font-size:13px;color:var(--grey-500);flex-wrap:wrap;gap:16px;
  }

  /* ---------- ANIMATIONS ---------- */
  @keyframes fadeUp{
    from{opacity:0;transform:translateY(24px)}
    to{opacity:1;transform:translateY(0)}
  }
  .reveal{opacity:0}
  .reveal.in{animation:fadeUp .8s cubic-bezier(.16,1,.3,1) forwards}
  .delay-1{animation-delay:.1s}
  .delay-2{animation-delay:.2s}
  .delay-3{animation-delay:.3s}
  .delay-4{animation-delay:.4s}
</style>
