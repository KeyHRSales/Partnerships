<script>
  // FAQ toggle
  function toggleFaq(btn){
    const item = btn.closest('.faq-item');
    const wasOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
    if(!wasOpen) item.classList.add('open');
  }

  // Form is a real POST to FormSubmit.co, browser handles native validation.
  // Visual focus style on invalid native validation:
  document.querySelectorAll('#partnerForm input, #partnerForm select, #partnerForm textarea').forEach(el => {
    el.addEventListener('invalid', function(){
      this.style.borderColor = '#E2231A';
      this.style.boxShadow = '0 0 0 3px rgba(226,35,26,.12)';
    });
    el.addEventListener('input', function(){
      if(this.checkValidity()){
        this.style.borderColor = '';
        this.style.boxShadow = '';
      }
    });
  });

  // Scroll reveal
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if(e.isIntersecting){
        e.target.classList.add('in');
        io.unobserve(e.target);
      }
    });
  }, {threshold:0.1});
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));
</script>


