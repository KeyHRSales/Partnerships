<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Become a Key HR Referral Partner | Human Capital, Upgraded.</title>
<meta name="description" content="Partner with Key HR, an ESAC-accredited PEO delivering modern HCM solutions. Earn competitive monthly commissions while protecting and elevating your clients." />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400;1,500;1,600;1,700;1,800&family=Inter+Tight:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{
    --red:#E2231A;
    --red-dark:#B81A12;
    --red-soft:#FDECEB;
    --black:#0B0B0D;
    --ink:#1A1A1E;
    --grey-900:#2A2A2F;
    --grey-700:#4A4A52;
    --grey-500:#7A7A82;
    --grey-300:#C9C9CF;
    --grey-200:#E4E4E8;
    --grey-100:#F1F1F3;
    --grey-50:#F8F8F9;
    --white:#FFFFFF;
    --serif:'Montserrat', 'Inter Tight', system-ui, sans-serif;
    --sans:'Inter Tight', system-ui, sans-serif;
  }
  *{margin:0;padding:0;box-sizing:border-box}
  html{scroll-behavior:smooth}
  body{
    font-family:var(--sans);
    color:var(--ink);
    background:var(--white);
    line-height:1.55;
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }
  a{color:inherit;text-decoration:none}
  img{display:block;max-width:100%}
  .container{max-width:1280px;margin:0 auto;padding:0 32px}
  @media (max-width:640px){.container{padding:0 20px}}

  /* ---------- NAV ---------- */
  .nav{
    position:sticky;top:0;z-index:100;
    background:rgba(255,255,255,0.92);
    backdrop-filter:blur(14px);
    -webkit-backdrop-filter:blur(14px);
    border-bottom:1px solid var(--grey-200);
  }
  .nav-inner{display:flex;align-items:center;justify-content:space-between;padding:18px 0}
  .nav-logo img{height:42px;width:auto}
  .nav-links{display:flex;gap:36px;align-items:center}
  .nav-links a{font-size:14px;font-weight:500;color:var(--grey-700);transition:color .2s}
  .nav-links a:hover{color:var(--black)}
  .btn{
    display:inline-flex;align-items:center;gap:8px;
    padding:13px 24px;border-radius:2px;
    font-family:var(--sans);font-weight:600;font-size:14px;
    letter-spacing:.02em;cursor:pointer;border:none;
    transition:all .25s ease;text-transform:uppercase;
  }
  .btn-red{background:var(--red);color:var(--white)}
  .btn-red:hover{background:var(--red-dark);transform:translateY(-1px);box-shadow:0 8px 20px rgba(226,35,26,.3)}
  .btn-black{background:var(--black);color:var(--white)}
  .btn-black:hover{background:var(--grey-900);transform:translateY(-1px)}
  .btn-outline{background:transparent;color:var(--black);border:1.5px solid var(--black)}
  .btn-outline:hover{background:var(--black);color:var(--white)}
  .btn-static{cursor:default;pointer-events:none}
  .btn-arrow::after{content:"→";font-size:16px;transition:transform .25s}
  .btn-arrow:hover::after{transform:translateX(4px)}
  @media (max-width:820px){.nav-links a:not(.btn){display:none}}

  /* ---------- HERO ---------- */
  .hero{
    position:relative;
    background:linear-gradient(180deg, var(--white) 0%, var(--grey-50) 100%);
    overflow:hidden;
    padding:80px 0 100px;
  }
  .hero::before{
    content:"";position:absolute;top:0;right:-10%;width:60%;height:100%;
    background:
      radial-gradient(circle at 70% 30%, rgba(226,35,26,.06), transparent 60%),
      linear-gradient(135deg, transparent 40%, rgba(11,11,13,.04) 100%);
    pointer-events:none;
  }
  .hero-content{
    position:relative;z-index:2;max-width:780px;
  }
  .eyebrow{
    display:inline-flex;align-items:center;gap:10px;
    font-size:12px;font-weight:600;letter-spacing:.18em;
    text-transform:uppercase;color:var(--red);
    margin-bottom:24px;
  }
  .eyebrow::before{
    content:"";width:32px;height:1.5px;background:var(--red);
  }
  .hero h1{
    font-family:var(--serif);
    font-weight:700;font-style:normal;
    font-size:clamp(48px, 7vw, 96px);
    line-height:.95;letter-spacing:-.025em;
    color:var(--black);
    margin-bottom:28px;
  }
  .hero h1 em{
    font-style:italic;font-weight:700;
    color:var(--red);
  }
  .hero h1 .upgraded{
    display:block;font-weight:800;font-style:italic;color:var(--red);
    letter-spacing:-.03em;
  }
  .hero-lead{
    font-size:21px;line-height:1.5;color:var(--ink);
    max-width:600px;margin-bottom:24px;font-weight:500;
  }
  .hero-supporting{
    font-size:16px;line-height:1.65;color:var(--grey-700);
    max-width:600px;margin-bottom:40px;
  }
  .hero-ctas{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:48px}
  .hero-trust{
    display:flex;align-items:center;gap:24px;flex-wrap:wrap;
    padding-top:28px;border-top:1px solid var(--grey-200);
  }
  .hero-trust-label{
    font-size:11px;font-weight:600;letter-spacing:.16em;
    text-transform:uppercase;color:var(--grey-500);
  }
  .hero-trust-badges{display:flex;gap:18px;align-items:center;flex-wrap:wrap}
  .trust-badge{
    font-family:var(--serif);font-weight:600;font-size:14px;
    color:var(--grey-700);letter-spacing:.02em;
    padding:6px 12px;border:1px solid var(--grey-300);border-radius:2px;
  }

  /* hero visual */
  .hero-visual{
    position:relative;
    aspect-ratio:1/1.15;
    width:100%;
    max-width:460px;
    margin-left:auto;
    margin-right:24px;
  }
  @media (max-width:980px){
    .hero-visual{margin:0 auto}
  }
  .hero-card-stack{
    position:relative;width:100%;height:100%;
  }
  .hc-bg{
    position:absolute;inset:0;
    background:var(--black);
    border-radius:4px;
    transform:rotate(-3deg) translate(-10px,10px);
    box-shadow:0 30px 60px rgba(0,0,0,.15);
  }
  .hc-bg::after{
    content:"";position:absolute;inset:0;
    background:
      repeating-linear-gradient(45deg, transparent, transparent 8px, rgba(255,255,255,.03) 8px, rgba(255,255,255,.03) 9px);
  }
  .hc-main{
    position:absolute;inset:0;
    background:linear-gradient(180deg, var(--white) 0%, var(--grey-50) 100%);
    border:1px solid var(--grey-200);
    border-radius:4px;
    padding:36px 32px;
    display:flex;flex-direction:column;justify-content:space-between;
    gap:24px;
    box-shadow:0 30px 80px rgba(0,0,0,.12);
    overflow:hidden;
  }
  .hc-header{
    display:flex;justify-content:space-between;align-items:flex-start;
    padding-bottom:24px;border-bottom:1px solid var(--grey-200);
  }
  .hc-header-label{
    font-size:10px;font-weight:700;letter-spacing:.2em;
    text-transform:uppercase;color:var(--grey-500);
  }
  .hc-header-value{
    font-family:var(--serif);font-size:18px;font-weight:600;color:var(--black);
    margin-top:4px;
  }
  .hc-red-tag{
    background:var(--red);color:var(--white);
    font-size:10px;font-weight:700;letter-spacing:.15em;
    padding:6px 10px;text-transform:uppercase;
  }
  .hc-stat-block{
    text-align:left;
  }
  .hc-stat-num{
    font-family:var(--serif);font-weight:300;
    font-size:clamp(72px, 10vw, 112px);
    line-height:.9;color:var(--black);letter-spacing:-.04em;
  }
  .hc-stat-num em{font-style:italic;color:var(--red);font-weight:400}
  .hc-stat-label{
    font-size:13px;font-weight:500;color:var(--grey-700);
    margin-top:14px;max-width:260px;line-height:1.45;
  }
  .hc-footer{
    display:grid;grid-template-columns:1fr 1fr;gap:20px;
    padding-top:24px;border-top:1px solid var(--grey-200);
  }
  .hc-mini{
    display:flex;flex-direction:column;
  }
  .hc-mini-num{
    font-family:var(--serif);font-weight:500;
    font-size:32px;color:var(--black);line-height:1;
  }
  .hc-mini-num.red{color:var(--red)}
  .hc-mini-label{
    font-size:11px;color:var(--grey-500);margin-top:6px;
    text-transform:uppercase;letter-spacing:.1em;font-weight:600;
  }
  .hc-corner{
    position:absolute;bottom:24px;right:-14px;
    background:var(--red);color:var(--white);
    padding:11px 16px;
    font-family:var(--serif);font-style:italic;font-weight:600;
    font-size:14px;
    box-shadow:0 12px 30px rgba(226,35,26,.35);
    transform:rotate(2deg);
    z-index:3;
  }

  /* ---------- METRICS BAR ---------- */
  .metrics{
    background:var(--black);
    color:var(--white);
    padding:64px 0;
    position:relative;
    overflow:hidden;
  }
  .metrics::before{
    content:"";position:absolute;top:0;left:0;right:0;height:1px;
    background:linear-gradient(90deg, transparent, var(--red), transparent);
  }
  .metrics-grid{
    display:grid;grid-template-columns:repeat(3,1fr);
    gap:0;
  }
  @media (max-width:820px){.metrics-grid{grid-template-columns:1fr;gap:48px}}
  .metric{
    text-align:left;padding:0 32px;
    border-right:1px solid rgba(255,255,255,.1);
  }
  .metric:last-child{border-right:none}
  .metric:first-child{padding-left:0}
  @media (max-width:820px){.metric{border-right:none;padding:0}}
  .metric-num{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(64px, 8vw, 110px);
    line-height:.9;letter-spacing:-.03em;
  }
  .metric-num em{font-style:italic;color:var(--red);font-weight:400}
  .metric-label{
    font-size:15px;color:var(--grey-300);
    margin-top:16px;max-width:280px;line-height:1.5;
  }

  /* ---------- WHY PARTNER ---------- */
  .why{padding:120px 0;background:var(--white)}
  .section-head{
    display:grid;grid-template-columns:.4fr .6fr;gap:64px;
    margin-bottom:80px;align-items:end;
  }
  @media (max-width:820px){.section-head{grid-template-columns:1fr;gap:24px;margin-bottom:48px}}
  .section-tag{
    font-size:12px;font-weight:600;letter-spacing:.2em;
    text-transform:uppercase;color:var(--red);
  }
  .section-title{
    font-family:var(--serif);font-weight:600;
    font-size:clamp(36px, 4.5vw, 60px);
    line-height:1.02;letter-spacing:-.02em;color:var(--black);
    margin-top:16px;
  }
  .section-title em{font-style:italic;color:var(--red);font-weight:600}
  .section-intro{
    font-size:18px;color:var(--grey-700);line-height:1.6;
  }
  .why-grid{
    display:grid;grid-template-columns:repeat(3,1fr);gap:0;
    border-top:1px solid var(--grey-200);
  }
  @media (max-width:820px){.why-grid{grid-template-columns:1fr}}
  .why-card{
    padding:48px 32px;
    border-right:1px solid var(--grey-200);
    border-bottom:1px solid var(--grey-200);
    position:relative;
    transition:background .3s;
  }
  .why-card:hover{background:var(--grey-50)}
  .why-card:nth-child(3n){border-right:none}
  .why-card:first-child{padding-left:0}
  .why-card:nth-child(3n+1){padding-left:0}
  @media (max-width:820px){
    .why-card{border-right:none;padding:40px 0 !important}
  }
  .why-card h3{
    font-family:var(--serif);font-weight:500;
    font-size:24px;line-height:1.2;color:var(--black);
    margin-bottom:14px;letter-spacing:-.01em;
    position:relative;padding-top:32px;
  }
  .why-card h3::before{
    content:"";position:absolute;top:0;left:0;
    width:32px;height:2px;background:var(--red);
  }
  .why-card p{
    font-size:15px;color:var(--grey-700);line-height:1.6;
  }

  /* ---------- COMMISSION SECTION ---------- */
  .commission{
    background:var(--black);color:var(--white);
    padding:120px 0;position:relative;overflow:hidden;
  }
  .commission::before{
    content:"";position:absolute;top:-200px;right:-200px;
    width:600px;height:600px;
    background:radial-gradient(circle, rgba(226,35,26,.15), transparent 70%);
    pointer-events:none;
  }
  .commission-grid{
    display:grid;grid-template-columns:.9fr 1.1fr;gap:80px;
    align-items:center;position:relative;z-index:2;
  }
  @media (max-width:980px){.commission-grid{grid-template-columns:1fr;gap:56px}}
  .commission .section-tag{color:var(--red)}
  .commission h2{
    font-family:var(--serif);font-weight:600;
    font-size:clamp(36px, 4.5vw, 56px);
    line-height:1.05;letter-spacing:-.02em;color:var(--white);
    margin-top:16px;margin-bottom:24px;
  }
  .commission h2 em{font-style:italic;color:var(--red);font-weight:600}
  .commission-lead{
    font-size:18px;color:var(--grey-300);line-height:1.6;
    margin-bottom:36px;
  }
  .benefits-list{list-style:none}
  .benefits-list li{
    display:flex;gap:20px;align-items:flex-start;
    padding:22px 0;border-bottom:1px solid rgba(255,255,255,.1);
  }
  .benefits-list li:first-child{padding-top:0}
  .benefits-list li:last-child{border-bottom:none}
  .benefit-icon{
    flex-shrink:0;width:44px;height:44px;
    background:var(--red);
    display:flex;align-items:center;justify-content:center;
    border-radius:2px;
  }
  .benefit-icon svg{width:20px;height:20px;stroke:var(--white)}
  .benefit-text h4{
    font-family:var(--serif);font-weight:500;font-size:20px;
    color:var(--white);margin-bottom:4px;
  }
  .benefit-text p{
    font-size:15px;color:var(--grey-300);line-height:1.55;
  }

  /* ---------- WHAT YOU OFFER ---------- */
  .offer{padding:120px 0;background:var(--grey-50)}
  .offer-grid{
    display:grid;grid-template-columns:repeat(2,1fr);gap:24px;
    margin-top:32px;
  }
  @media (max-width:780px){.offer-grid{grid-template-columns:1fr}}
  .offer-card{
    background:var(--white);
    padding:40px 36px;
    border:1px solid var(--grey-200);
    border-radius:2px;
    position:relative;
    transition:transform .3s, box-shadow .3s, border-color .3s;
  }
  .offer-card:hover{
    transform:translateY(-4px);
    border-color:var(--red);
    box-shadow:0 24px 50px rgba(0,0,0,.08);
  }
  .offer-card.featured{
    background:var(--black);color:var(--white);
    border-color:var(--black);
  }
  .offer-card.featured:hover{border-color:var(--red)}
  .offer-icon-wrap{
    display:inline-flex;align-items:center;justify-content:center;
    width:52px;height:52px;
    background:var(--red-soft);
    border-radius:2px;
    margin-bottom:24px;
  }
  .offer-card.featured .offer-icon-wrap{background:rgba(226,35,26,.15)}
  .offer-icon-wrap svg{width:24px;height:24px;stroke:var(--red)}
  .offer-card h3{
    font-family:var(--serif);font-weight:500;
    font-size:22px;color:var(--black);
    margin-bottom:10px;letter-spacing:-.01em;
  }
  .offer-card.featured h3{color:var(--white)}
  .offer-card .pill{
    display:inline-block;
    font-size:11px;font-weight:700;letter-spacing:.15em;
    text-transform:uppercase;color:var(--red);
    background:var(--red-soft);
    padding:5px 10px;border-radius:2px;
    margin-bottom:14px;
  }
  .offer-card p{
    font-size:15px;color:var(--grey-700);line-height:1.6;
  }
  .offer-card.featured p{color:var(--grey-300)}
  .offer-card .pill-light{
    background:rgba(226,35,26,.2);color:var(--red);
  }

  /* ---------- PROCESS TIMELINE ---------- */
  .process{padding:120px 0;background:var(--white)}
  .process-track{
    display:grid;grid-template-columns:repeat(4,1fr);gap:0;
    margin-top:64px;position:relative;
  }
  .process-track::before{
    content:"";position:absolute;top:32px;left:32px;right:32px;
    height:1px;background:var(--grey-200);
  }
  @media (max-width:820px){
    .process-track{grid-template-columns:1fr;gap:32px}
    .process-track::before{display:none}
  }
  .process-step{
    position:relative;z-index:2;padding-right:32px;
  }
  .process-step:last-child{padding-right:0}
  .process-num{
    display:flex;align-items:center;justify-content:center;
    width:64px;height:64px;
    background:var(--white);
    border:2px solid var(--black);
    border-radius:50%;
    font-family:var(--serif);font-weight:500;font-size:24px;
    color:var(--black);
    margin-bottom:28px;
    transition:all .3s;
  }
  .process-step:hover .process-num{
    background:var(--red);border-color:var(--red);color:var(--white);
    transform:scale(1.05);
  }
  .process-step h3{
    font-family:var(--serif);font-weight:500;font-size:22px;
    color:var(--black);margin-bottom:10px;letter-spacing:-.01em;
  }
  .process-step p{
    font-size:15px;color:var(--grey-700);line-height:1.55;
  }

  /* ---------- QUOTE / DIFFERENTIATOR ---------- */
  .pullquote{
    padding:120px 0;
    background:linear-gradient(135deg, var(--red) 0%, var(--red-dark) 100%);
    color:var(--white);position:relative;overflow:hidden;
  }
  .pullquote::before{
    content:""";position:absolute;
    top:-40px;left:40px;
    font-family:var(--serif);font-size:400px;font-weight:700;
    color:rgba(255,255,255,.08);line-height:1;
    pointer-events:none;
  }
  @media (max-width:640px){.pullquote::before{font-size:240px;top:0}}
  .pullquote-inner{
    max-width:900px;margin:0 auto;text-align:center;
    position:relative;z-index:2;
  }
  .pullquote blockquote{
    font-family:var(--serif);font-weight:500;font-style:italic;
    font-size:clamp(28px, 3.5vw, 44px);
    line-height:1.25;letter-spacing:-.01em;
    margin-bottom:32px;
  }
  .pullquote-attr{
    display:inline-flex;align-items:center;gap:14px;
    font-size:14px;font-weight:600;letter-spacing:.1em;
    text-transform:uppercase;color:rgba(255,255,255,.85);
  }
  .pullquote-attr::before{
    content:"";width:36px;height:1.5px;background:var(--white);
  }

  /* ---------- FORM / CTA ---------- */
  .signup{padding:120px 0;background:var(--grey-50)}
  .signup-grid{
    display:grid;grid-template-columns:.85fr 1.15fr;
    gap:80px;align-items:start;
  }
  @media (max-width:980px){.signup-grid{grid-template-columns:1fr;gap:56px}}
  .signup-left h2{
    font-family:var(--serif);font-weight:600;
    font-size:clamp(36px, 4.5vw, 56px);
    line-height:1.02;letter-spacing:-.02em;
    color:var(--black);margin-top:16px;margin-bottom:24px;
  }
  .signup-left h2 em{font-style:italic;color:var(--red);font-weight:500}
  .signup-left p{
    font-size:17px;color:var(--grey-700);line-height:1.6;
    margin-bottom:36px;
  }
  .signup-perks{
    display:flex;flex-direction:column;gap:14px;
    padding:28px;background:var(--white);
    border-left:3px solid var(--red);
  }
  .signup-perk{
    display:flex;align-items:flex-start;gap:14px;
    font-size:15px;color:var(--ink);line-height:1.5;
  }
  .signup-perk svg{
    flex-shrink:0;width:18px;height:18px;
    color:var(--red);margin-top:3px;
  }
  .form-wrap{
    background:var(--white);
    padding:48px;
    border:1px solid var(--grey-200);
    border-radius:2px;
    box-shadow:0 24px 60px rgba(0,0,0,.06);
  }
  @media (max-width:640px){.form-wrap{padding:32px 24px}}
  .form-title{
    font-family:var(--serif);font-weight:500;font-size:24px;
    color:var(--black);margin-bottom:6px;letter-spacing:-.01em;
  }
  .form-sub{
    font-size:14px;color:var(--grey-500);margin-bottom:28px;
  }
  .form-grid{
    display:grid;grid-template-columns:1fr 1fr;gap:16px;
  }
  @media (max-width:560px){.form-grid{grid-template-columns:1fr}}
  .form-field{display:flex;flex-direction:column;margin-bottom:16px}
  .form-field.full{grid-column:1/-1}
  .form-field label{
    font-size:12px;font-weight:600;letter-spacing:.05em;
    text-transform:uppercase;color:var(--grey-700);
    margin-bottom:8px;
  }
  .form-field label .req{color:var(--red)}
  .form-field input,
  .form-field select,
  .form-field textarea{
    width:100%;padding:13px 14px;
    border:1px solid var(--grey-300);
    border-radius:2px;
    background:var(--white);
    font-family:var(--sans);font-size:15px;
    color:var(--ink);
    transition:border-color .2s, box-shadow .2s;
  }
  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus{
    outline:none;border-color:var(--red);
